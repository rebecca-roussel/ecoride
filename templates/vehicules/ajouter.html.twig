{# templates/vehicules/ajouter.html.twig #}
{# Plan du fichier :

  1. Hériter de base.html.twig
     - le socle commun fournit l'en-tête, le pied de page
       et l'affichage global des messages flash

  2. Charger la feuille CSS propre au formulaire véhicule
     - elle complète les styles communs définis dans global.css

  3. Forcer l'en-tête utilisateur
     - cette page appartient à l'espace connecté

  4. Gérer deux usages dans le même écran
     - ajout d'un véhicule
     - modification d'un véhicule

  5. Afficher les erreurs locales du formulaire
     - ici, elles restent dans la page
     - elles ne doivent pas être remplacées par des flashs globaux
     - elles servent à corriger la saisie en cours

  6. Afficher le formulaire
     - champs
     - aides utilisateur
     - jeton CSRF
     - bouton enregistrer
     - lien annuler

  Point important :
  - les messages flash globaux ne sont plus affichés dans ce template
  - ils sont gérés dans base.html.twig
  - les erreurs de validation du formulaire restent ici,
    car elles font partie du traitement local de la saisie
#}

{% extends 'base.html.twig' %}

{% block title %}
{{ est_modification|default(false) ? 'Modifier un véhicule — EcoRide' : 'Ajouter un véhicule — EcoRide' }}
{% endblock %}

{% block stylesheets %}
	{{ parent() }}
	<link rel="stylesheet" href="{{ asset('css/vehicules_ajouter.css') }}">
{% endblock %}

{% block entete %}
	{# En-tête utilisateur :
	   cette page appartient à l'espace connecté. #}
	{% include 'fragments/entete_utilisateur.html.twig' %}
{% endblock %}

{# Si le contrôleur n'envoie pas explicitement la variable,
   on considère par défaut qu'on est dans le cas d'un ajout. #}
{% set est_modification = est_modification|default(false) %}

{% block body %}
	<main class="page_vehicule_ajouter">
		<section class="panneau_vehicule_ajouter" aria-labelledby="titre_page">

			{# En-tête de la page :
			   le titre s'adapte selon qu'on ajoute ou qu'on modifie un véhicule. #}
			<header class="entete_panneau">
				<h1 id="titre_page">
					{{ est_modification ? 'Modifier un véhicule' : 'Ajouter un véhicule' }}
				</h1>
				<p class="texte_secondaire">Renseignez les informations du véhicule.</p>
			</header>

			{# Erreur globale du formulaire :
			   elle reste affichée dans ce template
			   car elle concerne directement la saisie en cours. #}
			{% if erreurs.formulaire is defined %}
				<p class="champ_erreur" role="alert">{{ erreurs.formulaire }}</p>
			{% endif %}

			{# Formulaire principal :
			   - method POST : envoi des données au serveur
			   - action : route différente selon ajout ou modification
			   - jeton CSRF : protège contre une soumission forgée #}
			<form
				method="post"
				action="{{ est_modification
					? path('vehicule_modifier_traitement', { idVoiture: id_voiture })
					: path('vehicule_ajouter_traitement') }}"
				class="formulaire"
				novalidate
			>

				<input
					type="hidden"
					name="_jeton_csrf"
					value="{{ csrf_token(est_modification ? 'modifier_vehicule_' ~ id_voiture : 'ajouter_vehicule') }}"
				>

				<div class="champ">
					<label for="immatriculation">Immatriculation</label>

					{# Aide utilisateur :
					   on rappelle ici le format attendu avant la saisie. #}
					<p class="texte_mini texte_secondaire">
						Majuscules + chiffres uniquement (sans espaces). Exemple : AA123BB
					</p>

					<input
						id="immatriculation"
						name="immatriculation"
						required
						value="{{ valeurs.immatriculation|default('') }}"
						autocomplete="off"
						inputmode="text"
					>

					{% if erreurs.immatriculation is defined %}
						<p class="champ_erreur">{{ erreurs.immatriculation }}</p>
					{% endif %}
				</div>

				<div class="champ">
					<label for="date_1ere_mise_en_circulation">Date 1ère mise en circulation</label>

					<input
						id="date_1ere_mise_en_circulation"
						name="date_1ere_mise_en_circulation"
						type="date"
						required
						value="{{ valeurs.date_1ere_mise_en_circulation|default('') }}"
					>

					{% if erreurs.date_1ere_mise_en_circulation is defined %}
						<p class="champ_erreur">{{ erreurs.date_1ere_mise_en_circulation }}</p>
					{% endif %}
				</div>

				<div class="champ">
					<label for="marque">Marque</label>

					{# Aide utilisateur simple pour guider la saisie. #}
					<p class="texte_mini texte_secondaire">
						Exemple : Honda, Renault, Tesla
					</p>

					<input
						id="marque"
						name="marque"
						required
						value="{{ valeurs.marque|default('') }}"
						autocomplete="off"
					>

					{% if erreurs.marque is defined %}
						<p class="champ_erreur">{{ erreurs.marque }}</p>
					{% endif %}
				</div>

				<div class="champ">
					<label for="couleur">Couleur</label>

					{# Aide utilisateur simple pour guider la saisie. #}
					<p class="texte_mini texte_secondaire">
						Exemple : Rouge, Noir, Gris
					</p>

					<input
						id="couleur"
						name="couleur"
						required
						value="{{ valeurs.couleur|default('') }}"
						autocomplete="off"
					>

					{% if erreurs.couleur is defined %}
						<p class="champ_erreur">{{ erreurs.couleur }}</p>
					{% endif %}
				</div>

				<div class="champ">
					<label for="energie">Énergie</label>

					{# Dictionnaire d'affichage :
					   la base stocke des valeurs techniques en majuscules,
					   ici on les transforme en libellés lisibles. #}
					{% set libelles_energie = {
						'ESSENCE': 'Essence',
						'DIESEL': 'Diesel',
						'ETHANOL': 'Éthanol',
						'HYBRIDE': 'Hybride',
						'ELECTRIQUE': 'Électrique'
					} %}

					<select id="energie" name="energie" required>
						{% for e in ['ESSENCE','DIESEL','ETHANOL','HYBRIDE','ELECTRIQUE'] %}
							<option value="{{ e }}" {% if valeurs.energie|default('ESSENCE') == e %}selected{% endif %}>
								{{ libelles_energie[e] }}
							</option>
						{% endfor %}
					</select>

					{% if erreurs.energie is defined %}
						<p class="champ_erreur">{{ erreurs.energie }}</p>
					{% endif %}
				</div>

				<div class="champ">
					<label for="nb_places">Places</label>

					{# Le nombre de places reste volontairement borné de 1 à 4. #}
					<select id="nb_places" name="nb_places" required>
						{% for n in 1..4 %}
							<option value="{{ n }}" {% if valeurs.nb_places|default(1) == n %}selected{% endif %}>
								{{ n }}
							</option>
						{% endfor %}
					</select>

					{% if erreurs.nb_places is defined %}
						<p class="champ_erreur">{{ erreurs.nb_places }}</p>
					{% endif %}
				</div>

				{# Ligne d'actions :
				   - annuler revient vers la liste des véhicules
				   - enregistrer envoie le formulaire #}
				<div class="actions_formulaire">
					<a class="lien_annuler" href="{{ path('gerer_vehicules') }}">Annuler</a>
					<button class="bouton_principal" type="submit">Enregistrer</button>
				</div>
			</form>
		</section>
	</main>
{% endblock %}