{# templates/roles/index.html.twig #}
{# Plan du fichier :

  1. Hériter de base.html.twig
     - le socle commun fournit l'en-tête, le pied de page
       et l'affichage global des messages flash

  2. Charger la feuille CSS propre à la page des rôles
     - elle complète le style commun défini dans global.css

  3. Afficher le panneau principal
     - titre
     - sous-titre
     - formulaire de gestion des rôles

  4. Afficher les deux rôles modifiables
     - passager
     - chauffeur

  5. Protéger l'envoi du formulaire avec un jeton CSRF
     - la mise à jour des rôles passe par un POST

  Point important :
  - les messages flash ne sont plus affichés dans ce template
  - ils sont gérés globalement dans base.html.twig
  - en revanche, le fichier roles.js reste chargé,
    car il concerne le comportement propre à cette page
#}

{% extends 'base.html.twig' %}

{% block title %}
Gérer mes rôles
{% endblock %}

{% block stylesheets %}
	{{ parent() }}
	<link rel="stylesheet" href="{{ asset('css/roles.css') }}">
{% endblock %}

{% block body %}
	<main class="page_roles">
		<section class="panneau_roles">

			{# En-tête de la page :
			   on présente simplement l'action attendue de l'utilisateur. #}
			<h1>Gérer mes rôles</h1>
			<p class="texte_secondaire">
				Choisissez votre rôle sur la plateforme EcoRide
			</p>

			{# Formulaire principal :
			   il permet d'activer ou désactiver les rôles disponibles
			   pour le compte connecté. #}
			<form method="post" class="formulaire_roles">

				{# Jeton CSRF :
				   il protège l'envoi du formulaire. #}
				<input
					type="hidden"
					name="_csrf_token"
					value="{{ csrf_token('gerer_roles') }}"
				>

				{# Carte rôle passager :
				   ce rôle permet de rechercher et réserver des covoiturages. #}
				<div class="carte_role">
					<div class="role_infos">
						<div class="icone_role" aria-hidden="true">
							<span class="icone icone_avatar"></span>
						</div>

						<div>
							<h3>Passager</h3>
							<p class="texte_mini">
								Rechercher et réserver des covoiturages
							</p>
						</div>
					</div>

					<label class="interrupteur">
						<input type="checkbox" name="role_passager" {% if role_passager %}checked{% endif %}>
						<span class="curseur"></span>
					</label>
				</div>

				{# Carte rôle chauffeur :
				   ce rôle permet de publier des trajets et proposer des places. #}
				<div class="carte_role">
					<div class="role_infos">
						<div class="icone_role" aria-hidden="true">
							<span class="icone icone_covoit"></span>
						</div>

						<div>
							<h3>Chauffeur</h3>
							<p class="texte_mini">
								Publier des covoiturages et proposer des places
							</p>
						</div>
					</div>

					<label class="interrupteur">
						<input type="checkbox" name="role_chauffeur" {% if role_chauffeur %}checked{% endif %}>
						<span class="curseur"></span>
					</label>
				</div>

				{# Action de validation :
				   le bouton envoie les choix actuels au contrôleur. #}
				<button type="submit" class="bouton_principal bouton_roles">
					Enregistrer
				</button>

			</form>

		</section>
	</main>
{% endblock %}

{% block javascripts %}
	{{ parent() }}
	<script src="{{ asset('js/roles.js') }}" defer></script>
{% endblock %}