<!doctype html>
<html lang="fr">
	<head>
		<meta charset="utf-8">
		<meta name="viewport" content="width=device-width, initial-scale=1">
		<link rel="icon" type="image/svg+xml" href="{{ asset('icones/durable.svg') }}">

		<title>
			{% block title %}
				EcoRide
			{% endblock %}
		</title>

		<link rel="stylesheet" href="{{ asset('css/global.css') }}">
		<link rel="stylesheet" href="{{ asset('css/accueil.css') }}">
		{% block stylesheets %}{% endblock %}
	</head>

	<body>

		{# En-tête conditionnée #}
		{% block entete %}
			{% set est_connecte = app.session is not null and app.session.get('utilisateur_id') is not null %}

			{% if est_connecte %}
				{% include 'fragments/entete_utilisateur.html.twig' %}
			{% else %}
				{% include 'fragments/entete_public.html.twig' %}
			{% endif %}
		{% endblock %}

		{# Zone globale des messages flash :
		   elle est placée ici pour que tous les flashs
		   soient consommés et affichés au bon moment,
		   quelle que soit la page de destination. #}
		{% include 'fragments/messages_flash.html.twig' %}

		{% block body %}{% endblock %}

		{# Pied de page commun #}
		{% block pied_de_page %}
			{% include 'fragments/pied_de_page.html.twig' %}
		{% endblock %}

		{# JS commun menu mobile #}
		<script src="{{ asset('js/menu_navigation.js') }}"></script>

		{# JS global des messages flash :
		   il sert uniquement à faire disparaître visuellement
		   les messages après quelques secondes. #}
		<script src="{{ asset('js/messages_flash.js') }}"></script>

		{% block javascripts %}{% endblock %}

	</body>
</html>