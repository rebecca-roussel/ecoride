###> docker/compose ###
UID=1000
GID=1000
###< docker/compose ###

###> symfony/framework-bundle ###
APP_ENV=dev
APP_DEBUG=1
APP_TIMEZONE=Europe/Paris
###< symfony/framework-bundle ###

###> symfony/routing ###
DEFAULT_URI=http://localhost:8080
###< symfony/routing ###

###> postgresql ###
POSTGRES_DB=ecoride
POSTGRES_USER=ecoride
POSTGRES_PASSWORD=ecoride
POSTGRES_HOST=postgresql
POSTGRES_PORT=5432
DATABASE_URL=pgsql://ecoride:ecoride@postgresql:5432/ecoride
###< postgresql ###

###> mongodb ###
MONGO_URI=mongodb://mongodb:27017
MONGO_DB=ecoride_journal
MONGO_COLLECTION=journal_evenements
###< mongodb ###

###> symfony/mailer ###
MAILER_DSN=smtp://mailhog:1025
COURRIEL_EXPEDITEUR=nepasrepondre@ecoride.fr
